<odoo>
    <record id="view_chatbot_message_form" model="ir.ui.view">
        <field name="name">chatbot.message.form</field>
        <field name="model">chatbot.message</field>
        <field name="arch" type="xml">
            <form string="Chatbot Message">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="response" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_chatbot_message_tree" model="ir.ui.view">
        <field name="name">chatbot.message.tree</field>
        <field name="model">chatbot.message</field>
        <field name="arch" type="xml">
            <tree string="Chatbot Messages">
                <field name="name"/>
                <field name="response"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_chatbot_root" name="Chatbot"/>
    <menuitem id="menu_chatbot_messages" name="Messages" parent="menu_chatbot_root" action="action_chatbot_message"/>

    <record id="action_chatbot_message" model="ir.actions.act_window">
        <field name="name">Chatbot Messages</field>
        <field name="res_model">chatbot.message</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>