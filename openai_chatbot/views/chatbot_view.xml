<odoo>
    <data>
        <record id="view_chatbot_form" model="ir.ui.view">
            <field name="name">Chatbot</field>
            <field name="model">mail.channel</field>
            <field name="arch" type="form">
                <sheet>
                    <group>
                        <field name="name" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Chat">
                            <field name="message_ids" domain="[('model', '=', 'mail.channel'), ('res_id', '=', id)]" widget="mail_thread"/>
                            <div class="o_chat_input_container">
                                <textarea id="chat_input" placeholder="Escribe tu mensaje..."></textarea>
                                <button type="button" id="send_button" class="btn btn-primary">Enviar</button>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </field>
        </record>

        <record id="action_open_chatbot" model="ir.actions.act_window">
            <field name="name">Chatbot</field>
            <field name="res_model">mail.channel</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_chatbot" name="Chatbot" parent="mail.mail_menu_root" action="action_open_chatbot"/>
    </data>
</odoo>